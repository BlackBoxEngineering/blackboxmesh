{
  "name": "blackboxmesh-services",
  "version": "1.0.0",
  "description": "BlackBoxMesh bridge services",
  "scripts": {
    "build": "tsc",
    "mqtt": "ts-node mqtt-bridge.ts",
    "gps": "ts-node gps-bridge.ts",
    "serial": "ts-node serial-bridge.ts",
    "decoder": "ts-node meshtastic-decoder.ts --live",
    "decode": "ts-node meshtastic-decoder.ts",
    "all": "concurrently -n \"MQTT,GPS,SERIAL,DECODER\" -c \"blue,green,magenta,yellow\" \"npm run mqtt\" \"npm run gps\" \"npm run serial\" \"npm run decoder\""
  },
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "serialport": "^12.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
